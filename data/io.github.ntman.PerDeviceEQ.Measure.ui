<?xml version="1.0" encoding="UTF-8"?>
<!--
  per-device-eq measurement wizard skeleton (GtkBuilder), mirroring the main
  window's .ui conventions. The DEVICE is fixed (the wizard measures one
  sink), so the header just names it. First the measurement MIC and its
  calibration as a boxed list with the controls on the right (like the main
  window's Profile row). Then the RING as the spatial channel selector (the
  wizard's analogue of the main window's channel tabs), the status line, the
  centre pult (measure, stop, auto-level), the selected channel's page, and
  the Create button. Everything dynamic is built in code and dropped into the
  *_host containers: the ring buttons and their status bubbles, the pult
  buttons, the mic/capsules/calibration controls (added as row suffixes), and
  the selected channel's page (perdeviceeq/measure_window.py).
-->
<interface>
  <requires lib="gtk" version="4.0"/>
  <requires lib="libadwaita" version="1.0"/>

  <object class="AdwToolbarView" id="content">
    <child type="top">
      <object class="AdwHeaderBar" id="header_bar">
        <child type="title">
          <object class="AdwWindowTitle" id="window_title">
            <property name="title" translatable="yes">Measure speakers</property>
          </object>
        </child>
      </object>
    </child>
    <child>
      <object class="GtkScrolledWindow">
        <property name="vexpand">true</property>
        <property name="hscrollbar-policy">never</property>
        <child>
          <object class="AdwClamp">
            <property name="maximum-size">760</property>
            <property name="margin-top">12</property>
            <property name="margin-bottom">12</property>
            <property name="margin-start">12</property>
            <property name="margin-end">12</property>
            <child>
              <object class="GtkBox">
                <property name="orientation">vertical</property>
                <property name="spacing">18</property>

                <!-- 1. measurement mic + calibration (controls on the right,
                     added in code as row suffixes) -->
                <child>
                  <object class="AdwPreferencesGroup" id="mic_group">
                    <child>
                      <object class="AdwEntryRow" id="name_row">
                        <property name="title" translatable="yes">Profile name</property>
                      </object>
                    </child>
                    <child>
                      <object class="AdwActionRow" id="mic_row">
                        <property name="title" translatable="yes">Measurement mic</property>
                        <property name="subtitle" translatable="yes">Input the sweep is captured on</property>
                      </object>
                    </child>
                    <child>
                      <object class="AdwActionRow" id="capsules_row">
                        <property name="title" translatable="yes">Capsules</property>
                        <property name="subtitle" translatable="yes">Mono, or stereo like a UMIK rig</property>
                      </object>
                    </child>
                    <child>
                      <object class="AdwActionRow" id="cal_row">
                        <property name="title" translatable="yes">Calibration</property>
                        <property name="subtitle" translatable="yes">Mic calibration file per capsule</property>
                      </object>
                    </child>
                  </object>
                </child>

                <!-- 2. the ring: spatial channel selector, built in code and
                     dropped in here (with any rig-channel map slots) -->
                <child>
                  <object class="GtkBox" id="ring_host">
                    <property name="halign">center</property>
                  </object>
                </child>

                <!-- 3. status under the ring -->
                <child>
                  <object class="GtkLabel" id="status">
                    <property name="label" translatable="yes">Click a speaker to measure</property>
                    <property name="wrap">true</property>
                    <property name="justify">center</property>
                    <property name="halign">center</property>
                    <style>
                      <class name="dim-label"/>
                    </style>
                  </object>
                </child>

                <!-- warnings (sink gone, clipped, level, built in code) -->
                <child>
                  <object class="GtkLabel" id="warning">
                    <property name="xalign">0</property>
                    <property name="wrap">true</property>
                    <style>
                      <class name="dim-label"/>
                    </style>
                  </object>
                </child>

                <!-- 4. the pult: measure / stop / auto-level, built in code -->
                <child>
                  <object class="GtkBox" id="controls">
                    <property name="halign">center</property>
                    <property name="spacing">12</property>
                  </object>
                </child>

                <!-- 5. the selected channel's page: its takes + summary -->
                <child>
                  <object class="GtkBox" id="channel_host">
                    <property name="orientation">vertical</property>
                    <property name="spacing">12</property>
                  </object>
                </child>

                <!-- the EQ-range strip (global for now; built in code) -->
                <child>
                  <object class="GtkBox" id="fit_host">
                    <property name="orientation">vertical</property>
                  </object>
                </child>

                <!-- 6. build the profile from the confirmed channels -->
                <child>
                  <object class="GtkBox">
                    <property name="halign">end</property>
                    <child>
                      <object class="GtkButton" id="create_btn">
                        <property name="label" translatable="yes">Create profile</property>
                        <property name="sensitive">false</property>
                        <style>
                          <class name="suggested-action"/>
                        </style>
                      </object>
                    </child>
                  </object>
                </child>

              </object>
            </child>
          </object>
        </child>
      </object>
    </child>
  </object>
</interface>
