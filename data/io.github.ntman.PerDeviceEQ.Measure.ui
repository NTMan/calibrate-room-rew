<?xml version="1.0" encoding="UTF-8"?>
<!--
  per-device-eq measurement window skeleton (GtkBuilder).

  The DEVICE is fixed (the window measures one sink), so the header just
  names it. The content is an AdwMultiLayoutView with two declarative
  arrangements of the same seven blocks, the upstream-blessed way to
  do adaptive layouts instead of reparenting by hand:

    narrow  one clamped column inside one page scroller: profile name +
            mic + calibration, the ring (the spatial channel selector),
            the status line, the pult, the selected channel's
            takes, the EQ-range strip. Everything scrolls as one.

    wide    two columns: the left (mic, ring, status, pult)
            is pinned with no scroll of its own; the right (takes +
            EQ range) carries the single scroller, its bar at the
            window edge.

  The breakpoint in code only flips layout-name. Everything dynamic is
  built in code and dropped into the *_host containers and *_controls
  boxes (perdeviceeq/measure_window.py).
-->
<interface>
  <requires lib="gtk" version="4.0"/>
  <requires lib="libadwaita" version="1.6"/>

  <object class="AdwToolbarView" id="content">
    <child type="top">
      <object class="AdwHeaderBar" id="header_bar">
        <child type="title">
          <object class="GtkDropDown" id="sink_dd">
            <property name="tooltip-text" translatable="yes">The output the sweep plays into; switching parks this sitting and continues it there</property>
          </object>
        </child>
      </object>
    </child>
    <child type="top">
      <object class="AdwBanner" id="gone_banner">
        <property name="title" translatable="yes">The output device is gone</property>
      </object>
    </child>
    <child type="top">
      <object class="AdwBanner" id="mic_banner">
        <property name="title" translatable="yes">The measurement mic is gone</property>
      </object>
    </child>
    <child>
      <object class="AdwMultiLayoutView" id="mlv">

        <child>
          <object class="AdwLayout">
            <property name="name">narrow</property>
            <property name="content">
              <object class="GtkScrolledWindow">
                <property name="vexpand">true</property>
                <property name="hscrollbar-policy">never</property>
                <child>
                  <object class="AdwClamp">
                    <property name="maximum-size">760</property>
                    <property name="margin-top">12</property>
                    <property name="margin-bottom">12</property>
                    <property name="margin-start">12</property>
                    <property name="margin-end">12</property>
                    <child>
                      <object class="GtkBox">
                        <property name="orientation">vertical</property>
                        <property name="spacing">18</property>
                        <child>
                          <object class="AdwLayoutSlot">
                            <property name="id">mic</property>
                          </object>
                        </child>
                        <child>
                          <object class="AdwLayoutSlot">
                            <property name="id">ring</property>
                          </object>
                        </child>
                        <child>
                          <object class="AdwLayoutSlot">
                            <property name="id">channel</property>
                          </object>
                        </child>
                      </object>
                    </child>
                  </object>
                </child>
              </object>
            </property>
          </object>
        </child>

        <child>
          <object class="AdwLayout">
            <property name="name">wide</property>
            <property name="content">
              <object class="GtkBox">
                <property name="spacing">24</property>
                <!-- equal halves, ALWAYS: natural widths change
                     when the takes fold (hidden rows stop counting)
                     and the columns would breathe with every click
                     of the accordion -->
                <property name="homogeneous">true</property>
                <property name="margin-top">8</property>
                <property name="margin-bottom">8</property>
                <property name="margin-start">8</property>
                <child>
                  <object class="GtkScrolledWindow">
                    <property name="hscrollbar-policy">never</property>
                    <child>
                      <object class="GtkBox">
                        <property name="orientation">vertical</property>
                        <property name="spacing">18</property>
                        <property name="valign">start</property>
                        <property name="margin-top">4</property>
                        <property name="margin-bottom">4</property>
                        <property name="margin-start">4</property>
                        <property name="margin-end">4</property>
                    <child>
                      <object class="AdwLayoutSlot">
                        <property name="id">mic</property>
                      </object>
                    </child>
                    <child>
                      <object class="AdwLayoutSlot">
                        <property name="id">ring</property>
                      </object>
                    </child>
                      </object>
                    </child>
                  </object>
                </child>
                <child>
                  <object class="GtkScrolledWindow">
                    <property name="hexpand">true</property>
                    <property name="vexpand">true</property>
                    <property name="hscrollbar-policy">never</property>
                    <child>
                      <object class="GtkBox">
                        <property name="orientation">vertical</property>
                        <property name="spacing">18</property>
                        <property name="margin-top">4</property>
                        <property name="margin-bottom">4</property>
                        <property name="margin-start">4</property>
                        <property name="margin-end">12</property>
                        <child>
                          <object class="AdwLayoutSlot">
                            <property name="id">channel</property>
                          </object>
                        </child>
                      </object>
                    </child>
                  </object>
                </child>
              </object>
            </property>
          </object>
        </child>

        <!-- the seven blocks, slotted into whichever layout is active -->
        <child type="mic">
          <object class="AdwPreferencesGroup" id="mic_group">
            <child>
              <object class="AdwEntryRow" id="name_row">
                <property name="title" translatable="yes">Profile name</property>
              </object>
            </child>
            <child>
              <object class="AdwComboRow" id="source_row">
                <property name="title" translatable="yes">Measurement mic</property>
                <property name="subtitle" translatable="yes">Input the sweep is captured on</property>
              </object>
            </child>
            <child>
              <object class="AdwComboRow" id="chan_row">
                <property name="title" translatable="yes">Capsules</property>
                <property name="subtitle" translatable="yes">A UMIK-1 is mono even if it enumerates as stereo</property>
              </object>
            </child>
          </object>
        </child>
        <child type="ring">
          <object class="GtkBox">
            <style>
              <class name="card"/>
            </style>
            <child>
              <object class="GtkBox">
                <property name="orientation">vertical</property>
                <property name="spacing">6</property>
                <property name="margin-top">12</property>
                <property name="margin-bottom">12</property>
                <property name="margin-start">12</property>
                <property name="margin-end">12</property>
                <property name="hexpand">true</property>
                <child>
                  <object class="GtkBox" id="ring_host">
                    <property name="hexpand">true</property>
                  </object>
                </child>
                <child>
                  <object class="GtkBox" id="status_line">
                    <property name="spacing">12</property>
                    <child>
                      <object class="GtkBox" id="status_lead"/>
                    </child>
                    <child>
                      <object class="GtkLabel" id="status">
                        <property name="label" translatable="yes">Click a speaker to measure</property>
                        <property name="wrap">true</property>
                        <property name="max-width-chars">46</property>
                        <property name="justify">center</property>
                        <property name="halign">center</property>
                        <property name="hexpand">true</property>
                        <style>
                          <class name="dim-label"/>
                        </style>
                      </object>
                    </child>
                  </object>
                </child>
              </object>
            </child>
          </object>
        </child>
        <child type="channel">
          <object class="GtkBox" id="channel_host">
            <property name="orientation">vertical</property>
            <property name="spacing">12</property>
          </object>
        </child>
      </object>
    </child>
  </object>
</interface>
